{
    "protocol": "https://identity-iovf.xyz",
    "published": false,
    "types": {
      "invitation": {
        "schema": "https://identity-iovf.xyz/schemas/invitationCredentialSchema",
        "dataFormats": ["application/vc+jwt"]
      },
      "attendance": {
        "schema": "https://identity-iovf.xyz/schemas/attendanceCredentialSchema",
        "dataFormats": ["application/vc+jwt"]
      }
    },
    "structure": {
      "invitation": {
        "$actions": [
          {
            "who": "author",
            "of":"invitation",
            "can": ["create", "read"]
          },
          {
            "who": "recipient",
            "of":"invitation",
            "can": ["read"]
          }
        ]
      },
      "attendance": {
        "$actions": [
          {
            "who": "author",
            "of":"attendance",
            "can": ["create", "read"]
          },
          {
            "who": "recipient", 
            "of":"attendance",
            "can": ["read"]
          }
        ]
      }
    }
}