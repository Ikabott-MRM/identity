6)\":{\"params\":{\"claimHelperAddr\":\"The deployed address of THIS contract (not address(this) in delegatecall context)\",\"governor\":\"The GovernorRootstockCollective proxy address\",\"originalSingleton\":\"The Safe's current singleton to restore after claiming\",\"proposalId\":\"The governance proposal ID to execute\"}}},\"title\":\"ClaimHelper - Atomic singleton swap to let a Safe proxy receive RBTC via .send()\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"claimAndRestore(address,address,address,uint256)\":{\"notice\":\"Atomically: swap singleton -> execute governor proposal -> restore singleton\"}},\"notice\":\"Deployed on RSK mainnet to work around the 2300 gas stipend issue.         The Safe proxy's fallback always does SLOAD(800 gas) + DELEGATECALL(700 gas),         leaving only ~1317 gas for the singleton's receive(). The original Safe singleton         emits SafeReceived (LOG2 ~1381 gas) which exceeds 1317. This contract provides         an empty receive() that costs ~20 gas, fitting within the budget.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"contracts/ClaimHelper.sol\":\"ClaimHelper\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":@openzeppelin/=node_modules/@openzeppelin/\",\":eth-gas-reporter/=node_modules/eth-gas-reporter/\",\":forge-std/=lib/forge-std/src/\",\":hardhat/=node_modules/hardhat/\"]},\"sources\":{\"contracts/ClaimHelper.sol\":{\"keccak256\":\"0xaabe2ad2d15347a85255011a7cfb845908dce539c2f59be61cd56b8261964a3e\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://1aafdf951423dc7d115f1db37a83753eac78b32679b5ba04f7a874c968ab51c2\",\"dweb:/ipfs/QmSXcfePtZVxG58HvMrpZ45oEXwV65yd5rjhnNKJEjfjvh\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.33+commit.64118f21"},"language":"Solidity","output":{"abi":[{"inputs":[{"internalType":"address","name":"claimHelperAddr","type":"address"},{"internalType":"address","name":"originalSingleton","type":"address"},{"internalType":"address","name":"governor","type":"address"},{"internalType":"uint256","name":"proposalId","type":"uint256"}],"stateMutability":"nonpayable","type":"function","name":"claimAndRestore"},{"inputs":[],"stateMutability":"payable","type":"receive"}],"devdoc":{"kind":"dev","methods":{"claimAndRestore(address,address,address,uint256)":{"params":{"claimHelperAddr":"The deployed address of THIS contract (not address(this) in delegatecall context)","governor":"The GovernorRootstockCollective proxy address","originalSingleton":"The Safe's current singleton to restore after claiming","proposalId":"The governance proposal ID to execute"}}},"version":1},"userdoc":{"kind":"user","methods":{"claimAndRestore(address,address,address,uint256)":{"notice":"Atomically: swap singleton -> execute governor proposal -> restore singleton"}},"version":1}},"settings":{"remappings":["@openzeppelin/=node_modules/@openzeppelin/","eth-gas-reporter/=node_modules/eth-gas-reporter/","forge-std/=lib/forge-std/src/","hardhat/=node_modules/hardhat/"],"optimizer":{"enabled":false,"runs":200},"metadata":{"bytecodeHash":"ipfs"},"compilationTarget":{"contracts/ClaimHelper.sol":"ClaimHelper"},"evmVersion":"prague","libraries":{}},"sources":{"contracts/ClaimHelper.sol":{"keccak256":"0xaabe2ad2d15347a85255011a7cfb845908dce539c2f59be61cd56b8261964a3e","urls":["bzz-raw://1aafdf951423dc7d115f1db37a83753eac78b32679b5ba04f7a874c968ab51c2","dweb:/ipfs/QmSXcfePtZVxG58HvMrpZ45oEXwV65yd5rjhnNKJEjfjvh"],"license":"MIT"}},"version":1},"id":0}